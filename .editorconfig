root = true

# Note: the former CA1848 suppression was removed — all logging now uses LoggerMessage
# source-gen delegates (RequestLog / HealthLog / ExceptionLog), so the rule is satisfied,
# not suppressed.

[Functions/CorsPreflightFunction.cs]
# CA1822: "member 'Handle' can be marked static". Kept as an instance method for
# consistency with the other [Function] handler classes (which hold injected state).
# TODO(follow-up PR): make CorsPreflightFunction.Handle static.
dotnet_diagnostic.CA1822.severity = none
